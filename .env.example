APP_NAME=Creator Analytics Platform
APP_ENV=local

DATABASE_URL=sqlite:///./app.db

LOG_LEVEL=INFO

YOUTUBE_API_KEY=your_youtube_api_key_here

ENABLE_CRON_SYNC=true
CRON_SCHEDULE=0 */6 * * *

ALLOW_MANUAL_SYNC=true

YOUTUBE_MAX_CHANNELS_PER_RUN=25
YOUTUBE_MAX_VIDEOS_PER_CHANNEL=100

SEED_CHANNEL_IDS_FILE=seed_channels.json

# Optional: single Redis URL (used for CELERY_BROKER_URL and CELERY_RESULT_BACKEND if set)
# REDIS_URL=redis://localhost:6379/0
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0